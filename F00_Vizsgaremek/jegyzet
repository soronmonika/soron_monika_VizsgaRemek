    // BEVÉTELEK LEKÉRÉSE
    var xhrBevetel = new XMLHttpRequest();

    xhrBevetel.open("GET", "../api/bevetelek.php");

    xhrBevetel.onreadystatechange = function () {

    // ha a válasz megérkezett
    if (xhrBevetel.readyState == 4 && xhrBevetel.status == 200) {

    // JSON átalakítása
    var adatok = JSON.parse(xhrBevetel.responseText);

    // törzs kiválasztása
    var tbody = document.getElementById("bevetelekTorzs");
    tbody.innerHTML = "";

    // sorok létrehozása
    for (var i = 0; i < adatok.length; i++) {

      var tr=document.createElement("tr");

      var td1=document.createElement("td");
      td1.appendChild(document.createTextNode(adatok[i].Bevetelek_Id));

      var td2=document.createElement("td");
      td2.appendChild(document.createTextNode(adatok[i].Datum));

      var td3=document.createElement("td");
      td3.appendChild(document.createTextNode(adatok[i].Osszeg));

      var td4=document.createElement("td");
      td4.appendChild(document.createTextNode(adatok[i].Kategoria_Id));

      tr.appendChild(td1);
      tr.appendChild(td2);
      tr.appendChild(td3);
      tr.appendChild(td4);

      tbody.appendChild(tr);
      }
      }
      };

      xhrBevetel.send(null);
